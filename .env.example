# Coze 智能銷售 Bot（必填才能使用 AI 顧問頁面）
# 在 Coze 後台建立並發布 Agent 後，取得 Bot ID 與 Personal Access Token
COZE_BOT_ID=your_bot_id
COZE_API_KEY=your_personal_access_token

# 中國區 Coze 使用 api.coze.cn
# COZE_API_BASE=https://api.coze.cn

# Supabase：登录 / 订单 / Middleware（@supabase/ssr）必填
# 官方說明（Publishable / Secret vs Legacy anon / service_role）：
# https://supabase.com/docs/guides/api/api-keys
# Dashboard → Project Settings → API Keys：
# https://supabase.com/dashboard/project/_/settings/api-keys
#
# 變數名仍為 ANON_KEY（與 @supabase/ssr 範例一致），請貼入「低權限、可公開」的那把 key：
# - 首選：API Keys 分頁的 Publishable key（常見格式 sb_publishable_...）
# - 或過渡期：Legacy API Keys 分頁的 JWT anon key（儀表板標為 legacy）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_legacy_anon_key

# 僅 server 端 Demo API（getSupabaseAdminClient）使用，勿暴露到瀏覽器。
# 首選：API Keys 分頁的 Secret key（sb_secret_...）；或 Legacy 分頁的 JWT service_role key。
SUPABASE_SERVICE_ROLE_KEY=your_secret_or_legacy_service_role_key

# Agent 調用 Demo API 時帶入的 Header Token
AGENT_API_KEY=your_agent_api_key

# 子路径部署（GitHub Pages 等）。与 next.config 中 basePath 一致。
# Vercel 上不要设置本变量（构建时存在 VERCEL 则自动使用根路径 `/`）。
# NEXT_PUBLIC_BASE_PATH=/pureairweb

# Captcha 驗證碼設定
# 數學題簽發用 HMAC（生產環境必填，至少 16 字元）
CAPTCHA_HMAC_SECRET=your-random-secret-at-least-16-chars
CAPTCHA_ADMIN_TOKEN=your-admin-token
NEXT_PUBLIC_CAPTCHA_ENABLED=true
NEXT_PUBLIC_CAPTCHA_LOGIN_ENABLED=true
NEXT_PUBLIC_CAPTCHA_ORDER_ENABLED=true
CAPTCHA_RANDOM_TRIGGER_RATE=0.2
CAPTCHA_COOLDOWN_MINUTES=5
